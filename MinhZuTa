local ProTab = Window:CreateTab("Siêu cấp", 4483362458)

ProTab:CreateButton({
   Name = "Dịch chuyển đến Ma (Teleport)",
   Callback = function()
       local lp = game.Players.LocalPlayer.Character
       for _, v in pairs(game.Workspace:GetDescendants()) do
           if v:IsA("Model") and (string.find(v.Name:lower(), "ghost") or v:FindFirstChild("Humanoid")) and v.Name ~= game.Players.LocalPlayer.Name then
               lp.HumanoidRootPart.CFrame = v.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
               break
           end
       end
   end,
})

ProTab:CreateButton({
   Name = "Tự động thả đồ quanh Ma (Auto-Place)",
   Callback = function()
       local lp = game.Players.LocalPlayer
       local ghostPos = nil
       for _, v in pairs(game.Workspace:GetDescendants()) do
           if v:IsA("Model") and (string.find(v.Name:lower(), "ghost") or v:FindFirstChild("Humanoid")) and v.Name ~= lp.Name then
               ghostPos = v.HumanoidRootPart.CFrame
               break
           end
       end
       if ghostPos then
           for _, item in pairs(lp.Backpack:GetChildren()) do
               item.Parent = lp.Character
               task.wait(0.1)
               item.Handle.CFrame = ghostPos + Vector3.new(math.random(-3,3), 0, math.random(-3,3))
           end
       end
   end,
})

