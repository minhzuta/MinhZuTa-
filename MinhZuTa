-- typing effect
local function typeText(label, text, speed)
    speed = speed or 0.02
    label.Text = ""
    spawn(function()
        for i = 1, #text do
            label.Text = string.sub(text, 1, i)
            task.wait(speed)
        end
    end)
end

local function popupNotify(msg)
    typeText(Msg, msg, 0.02)
end

-- autorun
local autorunCancelled = false
local autorunThread
local function startAutoRun()
    if autorunThread then return end
    autorunCancelled = false
    autorunThread = spawn(function()
        local t0 = tick()
        while true do
            local elapsed = math.floor(tick() - t0)
            local left = AUTORUN_DELAY - elapsed
            if left <= 0 then
                Status.Text = "Đang chạy..."
                popupNotify("Tải và chạy Fram kẹo — giữ bình tĩnh...")
                local ok, err = fetchAndRunWithSuppress(SCRIPT_URL)
                if ok then
                    popupNotify("✅ Fram kẹo đã kích hoạt!")
                else
                    popupNotify("❌ Lỗi: "..tostring(err))
                end
                task.wait(1.2)
                pcall(function() ScreenGui:Destroy() end)
                autorunThread = nil
                return
            end
            if autorunCancelled then
                Status.Text = "Đã huỷ"
                popupNotify("Auto-run đã huỷ.")
                return
            end
            Status.Text = ("Auto run in %ds"):format(left)
            task.wait(1)
        end
    end)
end

