local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Demonology AUTO-DETECT | Anime Edition",
   LoadingTitle = "Đang phân tích dữ liệu game...",
   LoadingSubtitle = "by Gemini AI",
   ConfigurationSaving = { Enabled = true, FolderName = "AutoGhost" }
})

-- Tab Tự Động Xác Định
local AutoTab = Window:CreateTab("Tự Động Xác Định", 4483362458)

AutoTab:CreateSection("Hệ Thống Phân Tích Bằng Chứng")

local EvidenceFound = {} -- Nơi lưu bằng chứng quét được

-- Hàm thông báo khi tìm thấy ma
local function NotifyGhost(ghostName)
    Rayfield:Notify({
       Title = "⚠️ ĐÃ XÁC ĐỊNH THỰC THỂ!",
       Content = "Dựa trên bằng chứng, con ma này là: " .. ghostName:upper(),
       Duration = 10,
       Image = 4483362458,
    })
end

-- 1. CHỨC NĂNG TỰ ĐỘNG QUÉT (AUTO SCAN)
AutoTab:CreateButton({
   Name = "Kích hoạt Quét Bằng Chứng Tự Động",
   Callback = function()
       Rayfield:Notify({
          Title = "Hệ thống Bắt đầu",
          Content = "Đang quét các folder dữ liệu của Game...",
          Duration = 3,
       })
       
       -- ĐOẠN CODE LOGIC TỰ ĐỘNG (Cần tùy chỉnh theo cấu trúc mỗi game)
       task.spawn(function()
           while true do
               -- Ví dụ: Quét trong Folder 'Evidence' của người chơi hoặc của Map
               -- Đây là logic giả lập, bạn cần tìm đúng Folder chứa bằng chứng của game đó
               local ghostType = game.Workspace:FindFirstChild("GhostData") and game.Workspace.GhostData:GetAttribute("GhostType")
               
               if ghostType then
                   NotifyGhost(ghostType)
                   break -- Dừng quét khi đã tìm thấy
               end
               task.wait(5) -- Quét lại sau mỗi 5 giây
           end
       end)
   end,
})

-- 2. ESP NHÌN XUYÊN TÊN (Dành cho trường hợp game không ẩn dữ liệu)
local HackTab = Window:CreateTab("Hack & Di Chuyển", 4483362458)

HackTab:CreateToggle({
   Name = "Hiện tên thực thể ngay lập tức",
   CurrentValue = false,
   Callback = function(Value)
       _G.ShowName = Value
       while _G.ShowName do
           for _, v in pairs(game.Workspace:GetDescendants()) do
               -- Tìm các Object có thuộc tính giống con ma (thường là Model)
               if v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") and v.Name ~= game.Players.LocalPlayer.Name then
                   -- Tạo tag tên trên đầu nó
                   if not v.HumanoidRootPart:FindFirstChild("GhostTag") then
                       local tag = Instance.new("BillboardGui", v.HumanoidRootPart)
                       tag.Name = "GhostTag"
                       tag.Size = UDim2.new(0, 200, 0, 50)
                       tag.AlwaysOnTop = true
                       local text = Instance.new("TextLabel", tag)
                       text.Size = UDim2.new(1, 0, 1, 0)
                       text.Text = "THỰC THỂ: " .. v.Name
                       text.TextColor3 = Color3.fromRGB(255, 255, 0)
                       text.BackgroundTransparency = 1
                   end
               end
           end
           task.wait(2)
       end
   end,
})

-- 3. CHỨC NĂNG CHẠY NHANH & XUYÊN TƯỜNG
HackTab:CreateSlider({
   Name = "Tốc độ (Speed Hack)",
   Range = {16, 150},
   Increment = 1,
   CurrentValue = 16,
   Callback = function(Value)
      game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = Value
   end,
})

HackTab:CreateToggle({
   Name = "Đi xuyên vật cản (Noclip)",
   CurrentValue = false,
   Callback = function(v)
       _G.Noclip = v
       game:GetService("RunService").Stepped:Connect(function()
           if _G.Noclip and game.Players.LocalPlayer.Character then
               for _, part in pairs(game.Players.LocalPlayer.Character:GetDescendants()) do
                   if part:IsA("BasePart") then part.CanCollide = false end
               end
           end
       end)
   end,
})
