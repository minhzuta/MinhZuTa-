-- 1. EXP & Xác định sinh vật (Dựa trên danh sách ảnh)
MainTab:CreateSection("Xác định thực thể")

local ghostList = {
    "Aswang", "Banshee", "Demon", "Dullahan", "Dybbuk", "Entity", 
    "Ghoul", "Keres", "Leviathan", "Nightmare", "Oni", "Phantom", 
    "Revenant", "Shadow", "Siren", "Skinwalker", "Specter", "Spirit", 
    "Umbra", "Vex", "Wendigo", "The Wisp", "Wraith"
}

MainTab:CreateDropdown({
   Name = "Chọn thực thể để ghi chú/EXP",
   Options = ghostList,
   CurrentOption = {"Spirit"},
   MultipleOptions = false,
   Callback = function(Option)
      Rayfield:Notify({
         Title = "Đã xác định!",
         Content = "Thực thể hiện tại được đánh dấu là: " .. Option[1],
         Duration = 3,
