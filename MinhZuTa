-- 4. Nhìn thấy tên sinh vật (ESP - Đoạn code mẫu)
HackTab:CreateSection("ESP - Nhìn xuyên tường & Thấy tên")

local ESP_Enabled = false
HackTab:CreateToggle({
   Name = "Bật/Tắt ESP Thực thể (Xem tên)",
   CurrentValue = false,
   Flag = "ESPToggle",
   Callback = function(Value)
      ESP_Enabled = Value
      
      -- Xóa ESP cũ nếu có
      for _, v in pairs(game.CoreGui:GetChildren()) do
          if v.Name == "GhostESP_Holder" then
              v:Destroy()
          end
      end

      if ESP_Enabled then
          local ESPHolder = Instance.new("Folder")
          ESPHolder.Name = "GhostESP_Holder"
          ESPHolder.Parent = game.CoreGui

          -- HÀM TẠO ESP (Đây là đoạn code mẫu, có thể không chạy trên mọi game)
          local function CreateESP(part)
              if part:IsA("BasePart") or part:IsA("Model") then
                  local BillboardGui = Instance.new("BillboardGui")
                  local TextLabel = Instance.new("TextLabel")

                  BillboardGui.Parent = ESPHolder
                  BillboardGui.AlwaysOnTop = true
                  BillboardGui.Size = UDim2.new(0, 100, 0, 50)
                  BillboardGui.StudsOffset = Vector3.new(0, 3, 0) -- Hiển thị phía trên tên ma
                  BillboardGui.Adornee = part

                  TextLabel.Parent = BillboardGui
                  TextLabel.BackgroundTransparency = 1
                  TextLabel.Size = UDim2.new(1, 0, 1, 0)
                  TextLabel.Text = part.Name -- LẤY TÊN CỦA ĐỐI TƯỢNG TRONG GAME
                  TextLabel.TextColor3 = Color3.fromRGB(255, 0, 0) -- Màu đỏ
                  TextLabel.TextScaled = true
                  TextLabel.Font = Enum.Font.SourceSansBold
              end
          end

          -- QUÉT TÌM CON MA (Phần này cần chỉnh sửa cho từng game cụ thể)
          -- Ví dụ: Quét trong Workspace tìm các Model có tên chứa "Ghost" hoặc "Demon"
          game:GetService("RunService").Heartbeat:Connect(function()
              if not ESP_Enabled then return end
              for _, v in pairs(game.Workspace:GetDescendants()) do
                  -- CHÚ Ý: Cần thay đổi điều kiện "Ghost" hoặc "Demon" tùy theo game
                  if v:IsA("Model") and (string.match(v.Name, "Ghost") or string.match(v.Name, "Demon")) and not v:FindFirstChild("Humanoid") then 
                      if ESPHolder and not ESPHolder:FindFirstChild(v.Name .. "_ESP") then
                          local success, err = pcall(function()
                              CreateESP(v)
                              -- Đặt tên cho ESP để không tạo trùng
                              ESPHolder:FindFirstChild(v.Name .. "_ESP").Name = v.Name .. "_ESP" 
                          end)
                      end
                  end
              end
          end)
      end
   end,
})

HackTab:CreateParagraph({Title = "Lưu ý về ESP", Content = "ESP này là code mẫu. Nó chỉ hoạt động nếu con ma trong game được đặt tên là 'Ghost' hoặc 'Demon' trong hệ thống. Nếu không hiện tên, bạn cần script riêng cho game đó."})

-- 3. Chạy nhanh & 4. Đi xuyên tường (Noclip)
HackTab:CreateSection("Di chuyển")

local CurrentSpeed = 16
HackTab:CreateSlider({
   Name = "Tốc độ chạy (Speed)",
   Range = {16, 200},
   Increment = 1,
   Suffix = "Sps",
   CurrentValue = CurrentSpeed,
   Flag = "SpeedSlider",
   Callback = function(Value)
      CurrentSpeed = Value
      local char = game.Players.LocalPlayer.Character
      if char and char:FindFirstChild("Humanoid") then
          char.Humanoid.WalkSpeed = Value
      end
   end,
})

local Noclip = false
HackTab:CreateToggle({
   Name = "Đi xuyên vật cản (Noclip)",
   CurrentValue = false,
   Flag = "NoclipToggle",
   Callback = function(Value)
      Noclip = Value
      game:GetService("RunService").Stepped:Connect(function()
          if Noclip then
              local char = game.Players.LocalPlayer.Character
              if char then
                  for _, v in pairs(char:GetDescendants()) do
                      if v:IsA("BasePart") then
                          v.CanCollide = false
                      end
                  end
              end
          end
      end)
   end,
})

-- Tự động cập nhật tốc độ khi nhân vật respawn
game.Players.LocalPlayer.CharacterAdded:Connect(function(char)
    repeat task.wait() until char:FindFirstChild("Humanoid")
    char.Humanoid.WalkSpeed = CurrentSpeed
end)

