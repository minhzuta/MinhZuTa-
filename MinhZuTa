import pygame

pygame.init()

# Tạo cửa sổ game
screen = pygame.display.set_mode((800, 600))
pygame.display.set_caption("Anime Game")

# Tải ảnh
character = pygame.image.load("anime.png")

# Resize ảnh
character = pygame.transform.scale(character, (350, 450))

running = True
while running:
    screen.fill((20, 20, 20))

    # Hiển thị ảnh
    screen.blit(character, (220, 80))

    pygame.display.update()

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

pygame.quit()
