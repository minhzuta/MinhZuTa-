-- Danh sách thực thể: Aswang, Banshee, Demon, Dullahan, Dybbuk, Entity, Ghoul, 
-- Keres, Leviathan, Nightmare, Oni, Phantom, Revenant, Shadow, Siren, 
-- Skinwalker, Specter, Spirit, Umbra, Vex, Wendigo, The Wisp, Wraith.

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

-- --- CẤU HÌNH (Tùy chỉnh theo Game của bạn) ---
local Settings = {
    ExpPath = "EXP", -- Tên Object chứa EXP (VD: "Level", "Experience")
    TextSize = 14,
    TextColor = Color3.fromRGB(255, 0, 0), -- Màu đỏ (Ghost Style)
    UpdateRate = 0.1 -- Tốc độ làm mới (giây)
}

-- Danh sách tên quái từ ảnh (viết thường để so sánh chính xác)
local GhostList = {
    ["aswang"] = true, ["banshee"] = true, ["demon"] = true, ["dullahan"] = true,
    ["dybbuk"] = true, ["entity"] = true, ["ghoul"] = true, ["keres"] = true,
    ["leviathan"] = true, ["nightmare"] = true, ["oni"] = true, ["phantom"] = true,
    ["revenant"] = true, ["shadow"] = true, ["siren"] = true, ["skinwalker"] = true,
    ["specter"] = true, ["spirit"] = true, ["umbra"] = true, ["vex"] = true,
    ["wendigo"] = true, ["the wisp"] = true, ["wraith"] = true
}

-- Hàm tạo giao diện hiển thị
local function ApplyESP(model)
    if model:FindFirstChild("GhostESP_UI") then return end

    local head = model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart")
    if not head then return end

    local bill = Instance.new("BillboardGui")
    bill.Name = "GhostESP_UI"
    bill.Adornee = head
    bill.Size = UDim2.new(0, 200, 0, 50)
    bill.StudsOffset = Vector3.new(0, 3, 0)
    bill.AlwaysOnTop = true
    bill.Parent = model

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Settings.TextColor
    label.TextStrokeTransparency = 0.5
    label.TextScaled = false
    label.TextSize = Settings.TextSize
    label.Font = Enum.Font.SpecialElite -- Kiểu chữ kinh dị
    label.Parent = bill

    -- Vòng lặp cập nhật thông số
    task.spawn(function()
        while model.Parent and bill.Parent do
            local expValue = model:FindFirstChild(Settings.ExpPath)
            local expText = expValue and tostring(expValue.Value) or "0"
            
            label.Text = string.format("[%s]\nEXP: %s", model.Name:upper(), expText)
            task.wait(Settings.UpdateRate)
        end
    end)
end

-- Hàm kiểm tra và kích hoạt
local function CheckAndTag(obj)
    if obj:IsA("Model") and GhostList[obj.Name:lower()] then
        ApplyESP(obj)
    end
end

-- Quét toàn bộ quái đang có và quái mới sinh ra
for _, v in pairs(workspace:GetChildren()) do CheckAndTag(v) end
workspace.ChildAdded:Connect(CheckAndTag)

