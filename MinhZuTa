-- MinhZuTa v1.09 — Universal Edition (Auto-run 5s, POPUP, suppress new UI)
-- Compatible: Delta mobile (gethui), KRNL (CoreGui), Synapse, ArceusX, Fluxus...
-- Paste into your executor and Run in-game.

local AUTORUN_DELAY = 5     -- seconds before autorun
local SUPPRESS_DURATION = 3 -- seconds to actively remove new UI created by remote script
local SCRIPT_URL = "https://raw.githubusercontent.com/caomod2077/Script/refs/heads/main/FarmCandyFN.lua"

-- ---------- Utility: detect GUI parent ----------
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local function tryPlayerGui()
    local pl = Players.LocalPlayer
    if pl and pl:FindFirstChild("PlayerGui") then return pl.PlayerGui end
    return nil
end

local function detectGuiParent()
    -- 1) gethui / get_hidden_gui for mobile/exploit specific
    if type(gethui) == "function" then
        local ok, r = pcall(gethui)
        if ok and r then return r end
    end
    if type(get_hidden_gui) == "function" then
        local ok, r = pcall(get_hidden_gui)
        if ok and r then return r end
    end

    -- 2) PlayerGui if available (best for local UIs)
    local pg = tryPlayerGui()
    if pg then return pg end

    -- 3) CoreGui fallback (works on PC executors like KRNL)
    local ok, core = pcall(function() return game:GetService("CoreGui") end)
    if ok and core then return core end

    -- 4) last resort: wait a moment for PlayerGui
    for i = 1, 30 do
        pg = tryPlayerGui()
        if pg then return pg end
        task.wait(0.05)
    end

    return game:GetService("CoreGui")
end

local GuiParent = detectGuiParent()

-- ---------- Safe Instance creation ----------
local function safeNew(class, props)
    local ok, inst = pcall(Instance.new, class)
    if not ok or not inst then return nil end
    if props then
        for k,v in pairs(props) do
            pcall(function()
                if k == "Parent" then inst.Parent = v else inst[k] = v end
            end)
        end
    end
    return inst
end

-- Cleanup prior copies created by earlier runs
for _,v in ipairs(GuiParent:GetChildren()) do
    if v.Name and (v.Name:match("^MinhZuTa_v1_0[0-9]") or v.Name == "MinhZuTa_POPUP" or v.Name == "MinhZuTa_UNIV") then
        pcall(function() v:Destroy() end)
    end
end

-- ---------- Suppress utility ----------
local WHITELIST = { ["MinhZuTa_POPUP"] = true, ["MinhZuTa_UNIV"] = true, ["RobloxGui"] = true }
local function snapshotChildren(parent)
    local set = {}
    for _,c in ipairs(parent:GetChildren()) do set[c] = true end
    return set
end
local function destroyNewUIs(parent, before)
    for _,c in ipairs(parent:GetChildren()) do
        if not before[c] then
            local name = c.Name or ""
            if WHITELIST[name] then
                -- keep
            else
                local cls = c.ClassName
                if cls == "ScreenGui" or cls == "Frame" or cls == "TextLabel" or cls == "TextButton" or cls == "ImageLabel" or cls == "ScrollingFrame" then
                    pcall(function() c:Destroy() end)
                end
            end
        end
    end
end

-- ---------- Robust fetch ----------
local function fetchURL(url)
    -- 1) game:HttpGet
    local ok, res = pcall(function() if game and game.HttpGet then return game:HttpGet(url) end end)
    if ok and type(res) == "string" and #res > 10 then return true, res, "game:HttpGet" end

    -- 2) syn.request
    ok, res = pcall(function() if syn and syn.request then return syn.request({Url = url, Method="GET"}) end end)
    if ok and res and res.Body and #res.Body > 10 then return true, res.Body, "syn.request" end

    -- 3) http.request (some executors)
    ok, res = pcall(function() if http and http.request then return http.request({Url = url, Method="GET"}) end end)
    if ok and res and res.Body and #res.Body > 10 then return true, res.Body, "http.request" end

    -- 4) request
    ok, res = pcall(function() if request then return request({Url=url, Method="GET"}) end end)
    if ok and res and res.Body and #res.Body > 10 then return true, res.Body, "request" end

    -- 5) game:HttpGetAsync fallback
    ok, res = pcall(function() if game and game.HttpGetAsync then return game:HttpGetAsync(url) end end)
    if ok and type(res)=="string" and #res>10 then return true, res, "game:HttpGetAsync" end

    return false, nil, "no-method"
end

-- fetch and run while suppressing UI creations temporarily
local function fetchAndRunWithSuppress(url)
    local parent = GuiParent or game:GetService("CoreGui")
    local before = snapshotChildren(parent)
    local monitoring = true

    spawn(function()
        local t0 = tick()
        while monitoring and tick() - t0 <= SUPPRESS_DURATION do
            pcall(function() destroyNewUIs(parent, before) end)
            task.wait(0.12)
        end
    end)

    local ok, body, method = fetchURL(url)
    if not ok then
        monitoring = false
        return false, ("fetch failed - %s"):format(tostring(method))
    end

    local f, loadErr = loadstring(body)
    if not f then
        monitoring = false
        return false, ("loadstring failed: %s"):format(tostring(loadErr))
    end

    local okRun, runErr = pcall(f)
    task.wait(0.06)
    monitoring = false
    pcall(function() destroyNewUIs(parent, before) end)

    if not okRun then return false, runErr end
    return true
end

