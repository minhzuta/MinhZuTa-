-- [[ 1. CHỐNG AFK (ANTI-DISCONNECT) ]]
local VU = game:GetService("VirtualUser")
if not _G.AntiAFKLoaded then
    _G.AntiAFKLoaded = true
    game:GetService("Players").LocalPlayer.Idled:Connect(function()
        VU:CaptureController()
        VU:ClickButton2(Vector2.new())
    end)
end

-- [[ 2. TẠO GIAO DIỆN ]]
local CoreGui = game:GetService("CoreGui")
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AFK_Mobile_System"
ScreenGui.Parent = CoreGui
ScreenGui.IgnoreGuiInset = true

-- Khung nền đen
local BlackFrame = Instance.new("Frame")
BlackFrame.Parent = ScreenGui
BlackFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
BlackFrame.Size = UDim2.new(1, 0, 1, 0)
BlackFrame.Visible = true -- Mặc định bật khi chạy
BlackFrame.ZIndex = 10

-- Chữ thông báo
local InfoLabel = Instance.new("TextLabel")
InfoLabel.Parent = BlackFrame
InfoLabel.BackgroundTransparency = 1
InfoLabel.Size = UDim2.new(1, 0, 1, 0)
InfoLabel.Text = "ĐANG TREO MÁY...\n(Bấm nút tròn để tắt/mở)"
InfoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
InfoLabel.TextSize = 20
InfoLabel.Font = Enum.Font.SourceSansBold

-- Nút bấm Bật/Tắt (Nút này sẽ luôn nằm trên cùng)
local ToggleBtn = Instance.new("TextButton")
ToggleBtn.Parent = ScreenGui
ToggleBtn.Name = "ToggleAFK"
ToggleBtn.Size = UDim2.new(0, 50, 0, 50)
ToggleBtn.Position = UDim2.new(0, 10, 0.5, -25) -- Nằm ở giữa cạnh trái màn hình
ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Màu đỏ cho dễ thấy
ToggleBtn.Text = "ON"
ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleBtn.Font = Enum.Font.SourceSansBold
ToggleBtn.TextSize = 18
ToggleBtn.ZIndex = 20 -- Luôn nằm trên lớp màu đen

-- Bo tròn nút cho đẹp
local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(1, 0)
UICorner.Parent = ToggleBtn

-- [[ 3. XỬ LÝ BẤM NÚT ]]
ToggleBtn.MouseButton1Click:Connect(function()
    if BlackFrame.Visible then
        BlackFrame.Visible = false
        ToggleBtn.Text = "OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- Đổi sang xanh khi tắt
    else
        BlackFrame.Visible = true
        ToggleBtn.Text = "ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Đổi sang đỏ khi bật
    end
end)
