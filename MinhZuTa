-- [[ CẤU HÌNH ]]
local PHIM_TAT = Enum.KeyCode.K -- Bạn có thể đổi 'K' thành phím khác nếu muốn

-- [[ 1. TÍNH NĂNG CHỐNG AFK (ANTI-DISCONNECT) ]]
-- Tự động chạy ngầm ngay khi dán script
local VU = game:GetService("VirtualUser")
if _G.AntiAFKLoaded then
    print("Anti-AFK đã hoạt động từ trước.")
else
    _G.AntiAFKLoaded = true
    game:GetService("Players").LocalPlayer.Idled:Connect(function()
        VU:CaptureController()
        VU:ClickButton2(Vector2.new())
    end)
    print("Kích hoạt Anti-AFK thành công!")
end

-- [[ 2. TẠO GIAO DIỆN MÀN HÌNH ĐEN ]]
local CoreGui = game:GetService("CoreGui")
local ScreenGui = Instance.new("ScreenGui")
local Frame = Instance.new("Frame")
local StatusLabel = Instance.new("TextLabel")

ScreenGui.Name = "BlackScreen_System"
ScreenGui.Parent = CoreGui
ScreenGui.IgnoreGuiInset = true -- Che cả thanh Taskbar của Roblox

Frame.Parent = ScreenGui
Frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Màu đen
Frame.Size = UDim2.new(1, 0, 1, 0)
Frame.Active = true

StatusLabel.Parent = Frame
StatusLabel.BackgroundTransparency = 1
StatusLabel.Position = UDim2.new(0.5, -200, 0.5, -50)
StatusLabel.Size = UDim2.new(0, 400, 0, 100)
StatusLabel.Font = Enum.Font.Code
StatusLabel.Text = "STATUS: AFK MODE ACTIVE\n\n[Press '"..PHIM_TAT.Name.."' to Toggle]"
StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 0) -- Chữ màu xanh neon cho chuyên nghiệp
StatusLabel.TextSize = 22

-- [[ 3. HÀM BẬT/TẮT BẰNG PHÍM ]]
game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == PHIM_TAT then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end)
