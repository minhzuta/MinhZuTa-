-- [[ GHOST ESP - MINHZUTA ]] --
local GhostList = {"aswang", "banshee", "demon", "dullahan", "dybbuk", "entity", "ghoul", "keres", "leviathan", "nightmare", "oni", "phantom", "revenant", "shadow", "siren", "skinwalker", "specter", "spirit", "umbra", "vex", "wendigo", "the wisp", "wraith"}

local function CreateESP(m)
    if m:FindFirstChild("Zuta_ESP") then return end
    local h = m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("Head")
    if not h then return end

    local b = Instance.new("BillboardGui", m)
    b.Name = "Zuta_ESP"
    b.AlwaysOnTop, b.Size, b.StudsOffset = true, UDim2.new(0,200,0,50), Vector3.new(0,3,0)

    local t = Instance.new("TextLabel", b)
    t.Size, t.BackgroundTransparency, t.TextScaled = UDim2.new(1,0,1,0), 1, true
    t.TextColor3, t.Font = Color3.fromRGB(255, 0, 0), Enum.Font.Code

    task.spawn(function()
        while m.Parent and b.Parent do
            local exp = m:FindFirstChild("EXP") or m:FindFirstChild("Experience") or (m:FindFirstChild("Stats") and m.Stats:FindFirstChild("EXP"))
            t.Text = string.upper(m.Name) .. "\nEXP: " .. (exp and tostring(exp.Value) or "0")
            task.wait(1)
        end
    end)
end

local function check(o)
    if o:IsA("Model") then
        for _, g in pairs(GhostList) do
            if string.find(string.lower(o.Name), g) then CreateESP(o) break end
        end
    end
end

for _, v in pairs(workspace:GetDescendants()) do check(v) end
workspace.DescendantAdded:Connect(check)
print("MinhZuTa Ghost ESP Loaded!")
