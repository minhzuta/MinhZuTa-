-- Logic cập nhật chỉ số tự động
task.spawn(function()
    while true do
        local ghost = game.Workspace:FindFirstChild("Ghost") or game.Workspace:FindFirstChild("GhostData")
        if ghost then
            local name = ghost:GetAttribute("GhostType") or ghost.Name
            GhostName:Set("Ghost: " .. tostring(name):upper())
            Handprints:Set("Handprints: " .. (ghost:GetAttribute("Handprints") and "Yes" or "No"))
            Temperature:Set("Temperature: " .. (ghost:GetAttribute("Temp") or "0") .. "°C")
            GhostDetail:Set("Age: " .. (ghost:GetAttribute("Age") or "??") .. " | Room: " .. (ghost:GetAttribute("Room") or "???"))
        end
        task.wait(2)
    end
end)

-- ==========================================
-- TAB 2: ESP (VẬT PHẨM & MA)
-- ==========================================
local ESPTab = Window:CreateTab("ESP & Tầm nhìn", 4483362458)

local function ApplyESP(obj, text, color)
    if not obj:FindFirstChild("ProESP") then
        local gui = Instance.new("BillboardGui", obj)
        gui.Name = "ProESP"; gui.AlwaysOnTop = true; gui.Size = UDim2.new(0,100,0,50); gui.StudsOffset = Vector3.new(0,2,0)
        local lbl = Instance.new("TextLabel", gui)
        lbl.BackgroundTransparency = 1; lbl.Size = UDim2.new(1,0,1,0); lbl.Text = text; lbl.TextColor3 = color; lbl.TextScaled = true
    end
end

ESPTab:CreateToggle({
   Name = "ESP Vật Phẩm (EMF, Sổ, Đèn...)",
   CurrentValue = false,
   Callback = function(v)
       _G.Items = v
       while _G.Items do
           local itemList = {"EMF", "Writing", "Box", "Thermometer", "Camera", "Fuse", "Breaker"}
           for _, item in pairs(game.Workspace:GetDescendants()) do
               for _, n in pairs(itemList) do
                   if item:IsA("Model") and string.find(item.Name:lower(), n:lower()) then
                       ApplyESP(item, n, Color3.fromRGB(0, 255, 255))
                   end
               end
           end
           task.wait(5)
       end
   end,
})

ESPTab:CreateToggle({
   Name = "ESP Thực Thể (Ghost)",
   CurrentValue = false,
   Callback = function(v)
       _G.GhostESP = v
       while _G.GhostESP do
           for _, g in pairs(game.Workspace:GetDescendants()) do
               if g:IsA("Model") and (string.find(g.Name:lower(), "ghost") or g:FindFirstChild("Humanoid")) and g.Name ~= game.Players.LocalPlayer.Name then
                   ApplyESP(g, "⚠️ GHOST", Color3.fromRGB(255, 0, 0))
               end
           end
           task.wait(2)
       end
   end,
})

